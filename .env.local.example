# Copy this file to .env (local) and fill in real values.
# The .env file is gitignored — never commit real credentials.

# URL of your PHP wrapper's /api/v1 base (no trailing slash).
# Example for local dev: http://127.0.0.1:8080
LIVN_BACKEND_URL=http://127.0.0.1:8080

# If your PHP wrapper has OUR_API_KEY set, paste the same value here.
# Leave blank otherwise.
LIVN_BACKEND_KEY=

# Secret used to HMAC-sign voucher PDF tokens (lib/voucher-token.js).
# Anything random and long (≥ 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required: voucher links won't open without it.
VOUCHER_TOKEN_SECRET=

# Braintree — get these from the Braintree control panel.
# https://sandbox.braintreegateway.com  (or production.braintreegateway.com)
BRAINTREE_MERCHANT_ID=
BRAINTREE_PUBLIC_KEY=
BRAINTREE_PRIVATE_KEY=
BRAINTREE_ENVIRONMENT=Sandbox

# Booking notification SMTP. Leave host/user/pass blank to disable email
# (file-log in log/YYYY-MM-DD.jsonl still runs). Recipients are comma-
# separated. For Gmail use port 465 (implicit TLS) with an App Password
# generated at https://myaccount.google.com/apppasswords.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_TO=
